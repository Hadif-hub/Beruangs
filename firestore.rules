rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. DEFAULT-DENY SAFETY NET: Prevent any unintentional open exposure across the database
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. HARDENED GLOBAL HELPERS
    
    // Checks if the client holds an authenticated session token
    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the authenticated UID matches the record owner UID
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Validates that dynamic document IDs conform to safe rules
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper shorthand for the incoming resource state payload for writes
    function incoming() {
      return request.resource.data;
    }

    // Helper shorthand for existing database state
    function existing() {
      return resource.data;
    }

    // 3. BEAR POST SCHEMA VALIDATOR
    function isValidBearPost(data) {
      return data.keys().hasAll(['userId', 'userDisplayName', 'userPhotoURL', 'caption', 'imageUrl', 'isPublic', 'reactions', 'createdAt', 'updatedAt', 'comments'])
        && data.keys().size() == 10
        && isOwner(data.userId)
        && data.userDisplayName is string && data.userDisplayName.size() >= 1 && data.userDisplayName.size() <= 150
        && data.userPhotoURL is string && data.userPhotoURL.size() <= 2000
        && data.caption is string && data.caption.size() <= 10000
        && data.imageUrl is string && data.imageUrl.size() <= 1000000
        && data.isPublic is bool
        && data.reactions is map
        && data.comments is list && data.comments.size() <= 1000
        && data.createdAt is string && data.createdAt.size() >= 1 && data.createdAt.size() <= 64
        && data.updatedAt is string && data.updatedAt.size() >= 1 && data.updatedAt.size() <= 64;
    }

    // 4. BEAR POSTS CONSOLE RULES
    match /bear_posts/{postId} {
      // Allow single document get and queries (list) if public OR belonging to the owner
      allow get: if existing().isPublic == true || isOwner(existing().userId);
      allow list: if resource.data.isPublic == true || isOwner(resource.data.userId);

      // Create: Authenticated users can write a post/note adhering to schema and linked to their owner UID
      allow create: if isValidId(postId) && isValidBearPost(incoming());

      // Update:
      // Case A: Complete details update - Only author can change caption, title, visibility, etc.
      // Case B: Emoji react and comment updates - Any signed-in user can toggle reactions or add comments, altering only specified fields.
      allow update: if (
        isSignedIn() && (
          (isOwner(existing().userId) && isValidBearPost(incoming()) && incoming().userId == existing().userId && incoming().createdAt == existing().createdAt) ||
          (incoming().diff(existing()).affectedKeys().hasOnly(['reactions', 'comments', 'updatedAt']) && incoming().userId == existing().userId && incoming().caption == existing().caption && incoming().imageUrl == existing().imageUrl && incoming().isPublic == existing().isPublic)
        )
      );

      // Delete: Only the owner can remove a post
      allow delete: if isOwner(existing().userId);
    }
  }
}
